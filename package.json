{
  "name": "duet",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "duet": "dist/cli/duet.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "node --import tsx/esm --test",
    "verify": "npm run typecheck && npm run build && npm test"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
